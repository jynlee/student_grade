<?xml version="1.0" encoding="UTF-8"?>
<!--
  web.xml - 웹 애플리케이션 배포 설명자 (Deployment Descriptor)
  Tomcat이 이 파일을 읽어 웹 애플리케이션의 구조와 설정을 파악합니다.
  Spring MVC에서는 크게 두 가지 설정이 필요합니다:

  1. ContextLoaderListener: 애플리케이션 전체에서 공유하는 Spring 컨테이너 (root-context.xml)
     → Service, DAO, DataSource 같은 공통 빈(Bean)을 관리

  2. DispatcherServlet: HTTP 요청을 각 Controller로 분배하는 Front Controller (servlet-context.xml)
     → Controller, ViewResolver 같은 웹 계층 빈을 관리
-->
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <!-- ==================== 애플리케이션 기본 설정 ==================== -->
    <display-name>grade-system</display-name>

    <!-- ==================== 문자 인코딩 필터 ==================== -->
    <!--
      모든 요청과 응답에 UTF-8 인코딩을 적용합니다.
      이 필터가 없으면 POST 요청에서 한글이 깨질 수 있습니다.
      반드시 DispatcherServlet보다 먼저 선언해야 합니다.
    -->
    <filter>
        <filter-name>encodingFilter</filter-name>
        <filter-class>org.springframework.web.filter.CharacterEncodingFilter</filter-class>
        <init-param>
            <!-- 사용할 인코딩 방식 -->
            <param-name>encoding</param-name>
            <param-value>UTF-8</param-value>
        </init-param>
        <init-param>
            <!-- true: 요청(Request)과 응답(Response) 모두에 강제로 인코딩 적용 -->
            <param-name>forceEncoding</param-name>
            <param-value>true</param-value>
        </init-param>
    </filter>
    <filter-mapping>
        <filter-name>encodingFilter</filter-name>
        <!-- /*: 모든 URL 요청에 이 필터를 적용 -->
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- ==================== Root Application Context 설정 ==================== -->
    <!--
      contextConfigLocation: Root 컨텍스트 XML 파일의 위치를 지정합니다.
      root-context.xml에는 DB 연결, Service, DAO 등 공통 빈이 정의됩니다.
    -->
    <context-param>
        <param-name>contextConfigLocation</param-name>
        <param-value>/WEB-INF/root-context.xml</param-value>
    </context-param>

    <!--
      ContextLoaderListener: 웹 애플리케이션이 시작될 때 root-context.xml을 읽어
      Spring Root 컨테이너(ApplicationContext)를 생성합니다.
      애플리케이션 종료 시 컨테이너도 함께 종료합니다.
    -->
    <listener>
        <listener-class>org.springframework.web.context.ContextLoaderListener</listener-class>
    </listener>

    <!-- ==================== DispatcherServlet 설정 ==================== -->
    <!--
      DispatcherServlet: Spring MVC의 핵심 서블릿 (Front Controller 패턴)
      모든 HTTP 요청을 받아 적절한 Controller 메서드로 전달합니다.

      처리 흐름:
      클라이언트 요청 → DispatcherServlet → Controller → Service → DAO → DB
                                         ← View(JSP) ←        ←      ←
    -->
    <servlet>
        <servlet-name>appServlet</servlet-name>
        <servlet-class>org.springframework.web.servlet.DispatcherServlet</servlet-class>
        <init-param>
            <!-- 이 서블릿이 사용할 Spring 설정 파일 위치 -->
            <param-name>contextConfigLocation</param-name>
            <param-value>/WEB-INF/servlet-context.xml</param-value>
        </init-param>
        <!--
          load-on-startup: 서버 시작 시 이 서블릿을 미리 초기화합니다.
          숫자가 작을수록 먼저 초기화 (1 = 서버 시작하자마자 준비)
          설정하지 않으면 첫 번째 요청이 올 때 초기화되어 첫 요청이 느려집니다.
        -->
        <load-on-startup>1</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>appServlet</servlet-name>
        <!--
          /: 모든 요청을 DispatcherServlet이 처리합니다.
          (단, *.jsp 요청은 Tomcat의 JspServlet이 처리)
          /*로 설정하면 JSP 파일 요청도 DispatcherServlet이 가로채므로 / 사용 권장
        -->
        <url-pattern>/</url-pattern>
    </servlet-mapping>

    <!-- ==================== 기본 페이지 설정 ==================== -->
    <!--
      웹 루트(/)로 접속했을 때 보여줄 기본 파일 목록
      위에서부터 순서대로 찾아서 존재하는 파일을 보여줍니다.
    -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
        <welcome-file>index.html</welcome-file>
    </welcome-file-list>

    <!-- ==================== 에러 페이지 설정 ==================== -->
    <!-- 404 에러(페이지를 찾을 수 없음) 발생 시 보여줄 페이지 -->
    <error-page>
        <error-code>404</error-code>
        <location>/WEB-INF/views/error/404.jsp</location>
    </error-page>
    <!-- 500 에러(서버 내부 오류) 발생 시 보여줄 페이지 -->
    <error-page>
        <error-code>500</error-code>
        <location>/WEB-INF/views/error/500.jsp</location>
    </error-page>

</web-app>
