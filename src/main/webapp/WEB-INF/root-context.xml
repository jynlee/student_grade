<?xml version="1.0" encoding="UTF-8"?>
<!--
  root-context.xml - Spring Root Application Context 설정 파일
  웹 계층(Controller)을 제외한 모든 공통 빈(Bean)을 정의합니다.
  ContextLoaderListener가 서버 시작 시 이 파일을 읽어 Spring 컨테이너를 생성합니다.

  이 파일에서 관리하는 빈:
  - PropertyPlaceholderConfigurer: db.properties 파일을 읽어 ${변수명} 치환
  - DataSource: 데이터베이스 연결 정보 (DriverManagerDataSource)
  - JdbcTemplate: SQL 쿼리 실행을 도와주는 Spring JDBC 유틸리티
  - component-scan: @Service, @Repository 어노테이션이 붙은 클래스를 자동 등록
-->
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:context="http://www.springframework.org/schema/context"
       xsi:schemaLocation="
           http://www.springframework.org/schema/beans
           https://www.springframework.org/schema/beans/spring-beans.xsd
           http://www.springframework.org/schema/context
           https://www.springframework.org/schema/context/spring-context.xsd">

    <!-- ==================== 1. 프로퍼티 파일 로드 ==================== -->
    <!--
      PropertyPlaceholderConfigurer: classpath의 db.properties 파일을 읽어서
      이 XML 파일 안의 ${db.url}, ${db.username} 같은 플레이스홀더를 실제 값으로 치환합니다.

      예시: ${db.url} → jdbc:postgresql://postgres:5432/studentdb

      classpath: → src/main/resources/ 폴더를 의미합니다.
      Maven 빌드 시 resources 폴더의 파일들은 WEB-INF/classes/에 복사됩니다.
    -->
    <bean class="org.springframework.beans.factory.config.PropertyPlaceholderConfigurer">
        <property name="location" value="classpath:db.properties"/>
        <!-- 프로퍼티 파일이 없을 때 무시할지 여부 (false = 없으면 오류 발생) -->
        <property name="ignoreUnresolvablePlaceholders" value="false"/>
    </bean>

    <!-- ==================== 2. 컴포넌트 스캔 ==================== -->
    <!--
      component-scan: 지정한 패키지 하위에서 Spring 어노테이션이 붙은 클래스를 찾아
      자동으로 Bean으로 등록합니다.

      Root 컨텍스트에서는 웹 계층(@Controller)을 제외하고 스캔합니다.
      - @Service: 비즈니스 로직 클래스 (예: GradeServiceImpl)
      - @Repository: DB 접근 클래스 (예: GradeDaoImpl)
      - @Component: 일반 컴포넌트

      use-default-filters="false" + include-filter: @Controller를 제외하기 위해 사용
      (Controller는 servlet-context.xml에서 별도로 스캔)
    -->
    <context:component-scan base-package="com.example">
        <!-- @Controller와 @ControllerAdvice는 이 컨텍스트에서 스캔하지 않음 -->
        <context:exclude-filter type="annotation"
            value="org.springframework.stereotype.Controller"/>
        <context:exclude-filter type="annotation"
            value="org.springframework.web.bind.annotation.ControllerAdvice"/>
    </context:component-scan>

    <!-- ==================== 3. DataSource 빈 ==================== -->
    <!--
      DataSource: 데이터베이스 연결을 관리하는 객체입니다.
      JdbcTemplate이 이 DataSource를 통해 DB에 연결하고 쿼리를 실행합니다.

      DriverManagerDataSource: Spring이 제공하는 가장 단순한 DataSource 구현체
      - 매번 새로운 Connection을 생성합니다. (커넥션 풀 없음)
      - 개발/학습용으로 적합합니다.
      - 운영 환경에서는 HikariCP 같은 커넥션 풀 DataSource를 사용하세요.

      프로퍼티 값은 db.properties에서 읽어옵니다 (${} 구문으로 치환).
    -->
    <bean id="dataSource"
          class="org.springframework.jdbc.datasource.DriverManagerDataSource">

        <!-- JDBC 드라이버 클래스 이름: PostgreSQL 드라이버 -->
        <property name="driverClassName" value="${db.driver}"/>

        <!-- JDBC URL: PostgreSQL 서버 주소, 포트, 데이터베이스 이름 -->
        <property name="url" value="${db.url}"/>

        <!-- 데이터베이스 접속 계정 -->
        <property name="username" value="${db.username}"/>

        <!-- 데이터베이스 접속 비밀번호 -->
        <property name="password" value="${db.password}"/>

    </bean>

    <!-- ==================== 4. JdbcTemplate 빈 ==================== -->
    <!--
      JdbcTemplate: Spring JDBC의 핵심 클래스입니다.
      반복적인 JDBC 코드(Connection 획득, Statement 생성, ResultSet 처리, 예외 처리,
      Connection 반납)를 자동으로 처리해줍니다.

      개발자는 SQL 쿼리 작성과 결과 매핑에만 집중할 수 있습니다.

      사용 방법 (DAO 클래스에서):
        @Repository
        public class GradeDaoImpl implements GradeDao {
            @Autowired
            private JdbcTemplate jdbcTemplate;

            public List<Grade> findAll() {
                return jdbcTemplate.query("SELECT * FROM grades", new BeanPropertyRowMapper<>(Grade.class));
            }
        }
    -->
    <bean id="jdbcTemplate"
          class="org.springframework.jdbc.core.JdbcTemplate">
        <!-- 위에서 정의한 dataSource 빈을 주입 -->
        <property name="dataSource" ref="dataSource"/>
    </bean>

</beans>
