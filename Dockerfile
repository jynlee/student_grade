# ================================================================
# Dockerfile - 성적 관리 시스템 (grade-system)
# ================================================================
#
# [2단계 멀티스테이지 빌드(Multi-stage Build) 구조]
#
#   1단계 (builder): Maven으로 소스코드 → WAR 파일 빌드
#   2단계 (runtime): Tomcat 서버에 WAR 파일을 올려 실행
#
# 멀티스테이지를 쓰는 이유:
#   최종 이미지에 Maven, JDK 전체, 소스코드가 포함되지 않습니다.
#   → 이미지 크기가 훨씬 작아집니다. (보안 + 배포 속도 향상)
#
# [실행 방법]
#   docker compose up --build
# ================================================================


# ================================================================
# ─────────────────── 1단계: 빌드 (builder) ───────────────────
# ================================================================
#
# FROM <이미지>:<태그> AS <별칭>
#   maven:3.9-eclipse-temurin-11
#     - maven:3.9     → Maven 3.9 포함 (pom.xml 빌드 도구)
#     - eclipse-temurin-11 → Eclipse Adoptium OpenJDK 11
#   AS build → 이 단계를 'build'라는 이름으로 저장합니다.
#              2단계에서 COPY --from=build 로 참조합니다.
# ================================================================
FROM maven:3.9-eclipse-temurin-11 AS build

# ----------------------------------------------------------------
# WORKDIR: 이후 명령어들이 실행될 컨테이너 내부의 작업 디렉터리
# 경로가 없으면 자동 생성됩니다.
# ----------------------------------------------------------------
WORKDIR /app

# ----------------------------------------------------------------
# [의존성 캐싱 최적화 - 빌드 속도 향상]
#
# 순서:
#   1) pom.xml만 먼저 복사
#   2) mvn dependency:go-offline → 모든 라이브러리를 로컬 캐시에 다운로드
#   3) 이후 소스코드 복사 및 빌드
#
# 이렇게 하면:
#   - pom.xml이 바뀌지 않은 경우 Docker가 이 레이어를 캐시에서 재사용합니다.
#   - 즉, 소스코드만 수정했을 때는 라이브러리를 다시 다운로드하지 않습니다.
#   - 빌드 시간이 크게 단축됩니다. (첫 빌드만 시간이 걸립니다)
# ----------------------------------------------------------------
COPY pom.xml .

# -B: 배치(batch) 모드. 대화형 입력 없이 자동으로 진행합니다.
#     CI/CD 환경이나 Docker 빌드처럼 입력이 불가능한 환경에서 필수입니다.
RUN mvn dependency:go-offline -B

# ----------------------------------------------------------------
# 소스코드 전체를 컨테이너 /app/src 로 복사합니다.
# (pom.xml보다 나중에 복사해야 캐싱 효과가 있습니다)
# ----------------------------------------------------------------
COPY src ./src

# ----------------------------------------------------------------
# Maven 패키지 빌드
# mvn package: 컴파일 → 테스트 → WAR 파일 생성
# -DskipTests: 단위 테스트를 건너뜁니다.
#   이유: Docker 빌드 시점에는 DB 서버가 실행 중이지 않아
#         DB 연결이 필요한 테스트가 실패하기 때문입니다.
#
# 결과물: /app/target/grade-system.war
#         (pom.xml의 <finalName>grade-system</finalName> 에서 이름 결정)
# ----------------------------------------------------------------
RUN mvn package -DskipTests -B


# ================================================================
# ─────────────────── 2단계: 실행 (runtime) ───────────────────
# ================================================================
#
# tomcat:9.0-jdk11
#   - Tomcat 9.0 + OpenJDK 11 이 설치된 공식 이미지
#   - 1단계(build)와 달리 Maven이 없어 최종 이미지 크기가 작습니다.
# ================================================================
FROM tomcat:9.0-jdk11

# ----------------------------------------------------------------
# Tomcat 기본 웹앱 제거
#
# Tomcat 기본 이미지에는 아래 앱들이 포함되어 있습니다:
#   - ROOT    (기본 Tomcat 홈 화면)
#   - examples (서블릿/JSP 예제 - 보안 취약점 포함 가능)
#   - manager, host-manager (Tomcat 관리 콘솔 - 외부 노출 위험)
#   - docs
#
# 불필요한 앱을 제거해 보안을 강화하고 혼란을 줄입니다.
# ----------------------------------------------------------------
RUN rm -rf /usr/local/tomcat/webapps/*

# ----------------------------------------------------------------
# WAR 파일 배포
#
# COPY --from=build: 1단계(build)에서 만든 파일을 가져옵니다.
# /app/target/grade-system.war → ROOT.war 로 이름을 바꿔 복사
#
# [ROOT.war로 배포하는 이유]
#   Tomcat은 WAR 파일 이름이 컨텍스트 경로(Context Path)가 됩니다.
#
#   grade-system.war 로 배포하면:
#     http://localhost:8181/grade-system/ ← 경로가 필요
#
#   ROOT.war 로 배포하면:
#     http://localhost:8181/ ← 루트 경로에서 바로 접근 가능
#
#   ROOT.war → 컨텍스트 경로 = "" (빈 문자열)
#   JSP의 ${pageContext.request.contextPath} 도 자동으로 "" 반환
# ----------------------------------------------------------------
COPY --from=build /app/target/grade-system.war /usr/local/tomcat/webapps/ROOT.war

# ----------------------------------------------------------------
# EXPOSE: 컨테이너가 사용할 포트를 '문서화' 합니다.
# 실제로 포트를 열거나 외부에서 접속 가능하게 하는 것이 아닙니다.
# 외부 포트 연결은 docker-compose.yml의 ports 설정에서 합니다.
#
# Tomcat 기본 HTTP 포트: 8080
# docker-compose.yml에서 8181(외부) → 8080(컨테이너 내부) 로 연결합니다.
# ----------------------------------------------------------------
EXPOSE 8080

# ----------------------------------------------------------------
# 컨테이너 시작 명령어
#
# catalina.sh run: Tomcat을 포그라운드(foreground)로 실행합니다.
#   - 포그라운드: 프로세스가 터미널에 붙어서 실행됩니다.
#   - 컨테이너는 메인 프로세스가 실행 중일 때만 살아있습니다.
#   - 백그라운드로 실행하면 컨테이너가 즉시 종료됩니다!
#
# catalina.sh start 가 아닌 run을 사용해야 합니다.
# ----------------------------------------------------------------
CMD ["catalina.sh", "run"]
